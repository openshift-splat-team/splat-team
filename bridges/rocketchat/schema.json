{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "host": {
      "type": "string",
      "default": "127.0.0.1",
      "description": "Rocket.Chat server host"
    },
    "port": {
      "type": "integer",
      "default": 3000,
      "description": "Rocket.Chat server port"
    },
    "admin_username": {
      "type": "string",
      "default": "rcadmin",
      "description": "Rocket.Chat admin username"
    },
    "admin_password": {
      "type": "string",
      "description": "Rocket.Chat admin password"
    },
    "operator_id": {
      "type": "string",
      "description": "Rocket.Chat user ID of the team operator"
    },
    "create_token_secret": {
      "type": "string",
      "description": "Secret for users.createToken API"
    }
  },
  "required": ["host"]
}
